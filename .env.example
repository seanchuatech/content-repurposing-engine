# Server
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/content_engine
STORAGE_BACKEND=local # local | s3
SERVER_URL=http://localhost:3000/api
CLIENT_URL=http://localhost:5173

# Auth
JWT_SECRET=super-secret-change-me
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# ALLOWED_DEMO_EMAILS=your@email.com,another@email.com
RATE_LIMIT_MAX=100

# Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Workers / AI
LLM_BACKEND=gemini # gemini | openai
LLM_MODEL=gemini-1.5-flash
WHISPER_MODEL=tiny
MAX_VIDEO_DURATION_SECONDS=900
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# AWS / Production (Optional)
# AWS_REGION=ap-southeast-1
# S3_MEDIA_BUCKET=content-engine-media
# ECS_CLUSTER_ARN=your_ecs_cluster_arn
# WORKER_TASK_DEF_ARN=your_worker_task_definition_arn
# ECS_SUBNETS=subnet-1,subnet-2
# ECS_SECURITY_GROUPS=sg-1

# Client / Frontend
VITE_API_URL=http://localhost:3000/api
