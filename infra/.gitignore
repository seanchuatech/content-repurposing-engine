# infra/.gitignore
# Never commit Terraform state or secret variable files

# Terraform state
*.tfstate
*.tfstate.*
*.tfstate.backup

# Secret variable files
terraform.tfvars
*.auto.tfvars

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
